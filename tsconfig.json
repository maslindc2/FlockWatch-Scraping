{
    "exclude": [
        "./coverage",
        "./dist",
        "./docs",
        "tests",
        "jest.setup.ts",
        "jest.config.js",
        "init-mongo",
        "eslint.config.mjs",
        "playwright.config.ts",
        "setup-jest.js"
    ],
    "ts-node": {
        "transpileOnly": true,
        "files": true
    },
    "compilerOptions": {
        "target": "es2022",
        "module": "nodenext",
        "rootDir": "./src",
        "moduleResolution": "nodenext",
        "checkJs": true,
        "outDir": "./dist",
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "isolatedModules": true
    }
}
