{
    "name": "flockwatch-scraping",
    "version": "0.0.4",
    "main": "index.js",
    "scripts": {
        "test": "jest --coverage",
        "test:unit": "jest --testPathPatterns=tests/unit",
        "test:integration": "jest --testPathPatterns=tests/integration",
        "test:system": "jest --coverage --testPathPatterns=tests/system",
        "nodemon": "nodemon ./src/server.ts",
        "build": "tsc --project tsconfig.json",
        "dev": "npm run build && node ./dist/server.js",
        "docs": "typedoc",
        "docs:serve": "typedoc --watch",
        "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json)\"",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/maslindc2/FlockWatch-Scraping.git"
    },
    "author": "Maslin Farrell",
    "license": "ISC",
    "bugs": {
        "url": "https://github.com/maslindc2/FlockWatch-Scraping/issues"
    },
    "homepage": "https://github.com/maslindc2/FlockWatch-Scraping#readme",
    "description": "",
    "dependencies": {
        "axios": "^1.16.1",
        "compression": "^1.8.1",
        "cors": "^2.8.6",
        "cron": "^4.4.0",
        "csv": "^6.5.1",
        "csv-parse": "^6.2.1",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "mongoose": "^9.6.3",
        "node-cron": "^4.2.1",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@playwright/test": "^1.60.0",
        "@types/compression": "^1.8.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/express-rate-limit": "^6.0.2",
        "@types/jest": "^30.0.0",
        "@types/node": "^25.9.1",
        "@types/supertest": "^7.2.0",
        "eslint": "^10.4.0",
        "globals": "^17.6.0",
        "jest": "^30.4.2",
        "mongodb-memory-server": "^11.1.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.11",
        "ts-node": "^10.9.2",
        "typedoc": "^0.28.19",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0"
    }
